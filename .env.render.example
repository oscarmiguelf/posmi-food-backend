# ── Render Cloud (SYNC_MODE=cloud) ──────────────────────────────────────────
# Copy these into the Render dashboard → Environment → Environment Variables.
# Values marked GENERATE are auto-generated by render.yaml; set the rest manually.

NODE_ENV=production
PORT=3000

# Provided automatically by render.yaml fromDatabase binding
DATABASE_URL=postgresql://posmi:<password>@<host>:5432/posmi_food

# GENERATE in render.yaml — copy to note securely after first deploy
JWT_SECRET=<generate: openssl rand -hex 32>
JWT_REFRESH_SECRET=<generate: openssl rand -hex 32>

# Sync
SYNC_MODE=cloud
# HUB_SECRET must match the value set in each Local Hub's .env.local-hub
HUB_SECRET=<generate: openssl rand -hex 32>

# White-label client to load from config/clients/
CLIENT_NAME=default

# Logging
LOG_LEVEL=info

# Optional — Sentry error tracking
SENTRY_DSN=

# ── NOT needed in cloud mode (only in local_hub) ─────────────────────────────
# CLOUD_API_URL is only set on the Local Hub, not on the cloud instance
