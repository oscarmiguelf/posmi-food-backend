# ── Local Hub environment variables ──────────────────────────────────────────
# Copy to .env.local-hub and fill in before deploying to the NUC/mini-PC.

# PostgreSQL password for the local DB container
DB_PASSWORD=change_me_local

# JWT secret — must match the Cloud instance for token validation
JWT_SECRET=change_me_jwt_secret_32_chars_min

# URL of the Cloud instance this hub syncs with
CLOUD_API_URL=https://posmi-food-cloud.onrender.com

# Shared secret between Local Hub and Cloud for sync endpoints
# Generate with: openssl rand -hex 32
HUB_SECRET=change_me_hub_secret
